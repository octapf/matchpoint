{
  "version": 2,
  "buildCommand": "npx expo export -p web",
  "outputDirectory": "dist",
  "framework": null,
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 10
    }
  },
  "rewrites": [
    {
      "source": "/((?!api/)(?!.*\\.[a-zA-Z0-9]{2,6}$).*)",
      "destination": "/"
    }
  ]
}
