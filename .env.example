# Vercel API (backend)
# After deploying to Vercel, use your project URL (e.g. https://matchpoint-xxx.vercel.app)
EXPO_PUBLIC_API_URL=https://your-app.vercel.app

# Google OAuth (Web client ID - required for iOS and backend)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google OAuth Android client ID (optional; required for Google sign-in on Android)
# Falls back to web client if unset (app won't crash, but Android sign-in may fail)
# Create in Google Cloud Console: Credentials → Create OAuth client ID → Android
# Package: host.exp.Exponent (Expo Go) or com.miralab.matchpoint (dev build)
# SHA-1: from EAS credentials or keytool for your keystore
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Invite links base URL (for sharing tournament links)
# Used when building https://matchpoint.miralab.ar/t/{token}
EXPO_PUBLIC_INVITE_BASE_URL=https://matchpoint.miralab.ar

# Backend env (Vercel dashboard → Settings → Environment Variables)
# MONGODB_URI=<redacted-mongodb-uri>
# GOOGLE_CLIENT_ID=same as EXPO_PUBLIC_GOOGLE_CLIENT_ID
# GOOGLE_ANDROID_CLIENT_ID=same as EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID (optional; add if using Android OAuth)
