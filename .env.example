# --- Expo client (EXPO_PUBLIC_* is embedded at build time) ---
EXPO_PUBLIC_API_URL=
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
EXPO_PUBLIC_INVITE_BASE_URL=https://matchpoint.miralab.ar
# Sentry React Native (client). Create a RN project at https://sentry.io → copy DSN.
# EAS: use visibility "sensitive" or "plaintext" for EXPO_PUBLIC_* (not "secret" — EAS rejects it).
# Local dev: optional; production/preview EAS builds: set via EAS (see package.json eas:env:sentry*).
# EXPO_PUBLIC_SENTRY_DSN=
# Set to 1 or true to force local mocks even when API URL is set
# EXPO_PUBLIC_DEV_MOCK_DATA=
# Default weather when location is unavailable (Open-Meteo)
# EXPO_PUBLIC_WEATHER_DEFAULT_LAT=41.3851
# EXPO_PUBLIC_WEATHER_DEFAULT_LON=2.1734
# Optional: Facebook app id for OG tags on web
# EXPO_PUBLIC_FB_APP_ID=

# --- Vercel / API (server-side; never prefix with EXPO_PUBLIC_) ---
MONGODB_URI=
JWT_SECRET=
# Comma-separated emails promoted to admin on login
# ADMIN_EMAILS=
# Google OAuth (server): often same IDs as EXPO_PUBLIC_* for web/Android
# GOOGLE_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=
APP_URL=
# SMTP for password reset / verification (if used)
# EMAIL_USER=
# EMAIL_PASS=
