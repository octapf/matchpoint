# =============================================================================
# Client — copy to .env for local Expo (EXPO_PUBLIC_* are baked in at build time)
# =============================================================================

# Vercel API origin (no trailing slash), e.g. https://matchpoint-xxxx.vercel.app
EXPO_PUBLIC_API_URL=https://your-app.vercel.app

# Google OAuth Web client ID (iOS URL scheme in app.config.js derives from this)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# Google OAuth Android client ID (recommended for Android; package + SHA-1 must match GCP)
# Falls back to web client if empty — see docs/EXPO_AND_VERCEL.md
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Public base for invite links: https://<host>/t/{token}
EXPO_PUBLIC_INVITE_BASE_URL=https://matchpoint.miralab.ar

# Optional — set true to use local mock tournament/teams/entries/users while EXPO_PUBLIC_API_URL is set (restart Expo after change)
# EXPO_PUBLIC_DEV_MOCK_DATA=true

# Optional — Facebook App ID for fb:app_id meta / Sharing Debugger (developers.facebook.com → App → Settings)
# EXPO_PUBLIC_FB_APP_ID=

# =============================================================================
# Server only — set in Vercel Dashboard → Environment Variables (never EXPO_PUBLIC_)
# =============================================================================
# Local: copy MONGODB_URI here too so `npm run seed:dev` can seed dev tournament data (see scripts/seed-dev-tournament.cjs)
# MONGODB_URI=<redacted-mongodb-uri>
# GOOGLE_CLIENT_ID=same Web client ID as EXPO_PUBLIC_GOOGLE_CLIENT_ID
# GOOGLE_ANDROID_CLIENT_ID=same as EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID (optional)
# APPLE_CLIENT_ID=com.miralab.matchpoint (or your Services ID — match Apple Developer config)
# APP_URL=https://your-app.vercel.app
# JWT_SECRET=long-random-string-required-in-production
# Session JWT + email verification share JWT_SECRET on the server.

# Comma-separated admin emails (case-insensitive). On login, users get role=admin in MongoDB.
# ADMIN_EMAILS=you@example.com
# EMAIL_USER=your-smtp-user
# EMAIL_PASS=your-smtp-password
